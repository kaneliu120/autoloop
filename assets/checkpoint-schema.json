{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutoLoop Checkpoint",
  "description": "The checkpoint records only the task position, round, phase, and paused state. The single source of truth for the DECIDE→ACT strategy handoff (strategy_id / hypothesis / planned_commands) is plan.decide_act_handoff in autoloop-state.json under the work directory; it is not duplicated in this file.",
  "type": "object",
  "required": ["task_id", "current_round", "current_phase", "last_completed_phase", "timestamp"],
  "properties": {
    "task_id": {"type": "string", "description": "Task ID, e.g. T1-RESEARCH-001"},
    "current_round": {"type": "integer", "minimum": 0},
    "current_phase": {"type": "string", "enum": ["OBSERVE", "ORIENT", "DECIDE", "ACT", "VERIFY", "SYNTHESIZE", "EVOLVE", "REFLECT"]},
    "last_completed_phase": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "evolve_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "round": {"type": "integer"},
          "decision": {"type": "string", "enum": ["continue", "stop", "pause", "switch"]},
          "reason": {"type": "string"}
        }
      }
    },
    "pause_state": {
      "type": ["object", "null"],
      "properties": {
        "reason": {"type": "string"},
        "required_confirmation": {"type": "string"},
        "paused_at": {"type": "string", "format": "date-time"}
      }
    }
  }
}
