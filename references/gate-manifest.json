{
  "version": "1.0.0",
  "templates": {
    "T1": {
      "name": "Research",
      "gates": [
        {"dimension": "coverage", "threshold": 85, "unit": "%", "type": "hard", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "credibility", "threshold": 80, "unit": "%", "type": "hard", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "consistency", "threshold": 90, "unit": "%", "type": "soft", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "completeness", "threshold": 85, "unit": "%", "type": "soft", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}}
      ]
    },
    "T2": {
      "name": "Compare",
      "gates": [
        {"dimension": "coverage", "threshold": 100, "unit": "%", "type": "hard", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "credibility", "threshold": 80, "unit": "%", "type": "hard", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "bias_check", "threshold": 1, "unit": "bool", "type": "hard", "comparator": "=="},
        {"dimension": "sensitivity", "threshold": 1, "unit": "bool", "type": "soft", "comparator": "=="}
      ]
    },
    "T3": {
      "gates": [
        {"dimension": "design_completeness", "threshold": 7, "unit": "score", "type": "hard", "comparator": ">=", "note": "Proportion of requirements that have a corresponding design", "llm_grader": {"enabled": false, "prompt_file": "graders/design-feasibility.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "feasibility_score", "threshold": 7, "unit": "score", "type": "hard", "comparator": ">=", "note": "Technical feasibility (architecture, dependencies, risks)", "llm_grader": {"enabled": false, "prompt_file": "graders/design-feasibility.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "requirement_coverage", "threshold": 7, "unit": "score", "type": "hard", "comparator": ">=", "note": "Each requirement can be traced to a design-document section", "llm_grader": {"enabled": false, "prompt_file": "graders/design-feasibility.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "scope_precision", "threshold": 7, "unit": "score", "type": "soft", "comparator": ">=", "note": "IN/OUT are clear and dependencies are identified", "llm_grader": {"enabled": false, "prompt_file": "graders/design-feasibility.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "validation_evidence", "threshold": 7, "unit": "score", "type": "soft", "comparator": ">=", "note": "Feasibility checks and risk assessment are complete", "llm_grader": {"enabled": false, "prompt_file": "graders/design-feasibility.md", "trigger": "when_confidence_is_heuristic"}}
      ]
    },
    "T4": {
      "name": "Deliver",
      "gates": [
        {"dimension": "syntax_errors", "threshold": 0, "unit": "count", "type": "hard", "comparator": "=="},
        {"dimension": "p1_p2_issues", "threshold": 0, "unit": "count", "type": "hard", "comparator": "=="},
        {"dimension": "service_health", "threshold": 1, "unit": "bool", "type": "soft", "comparator": "=="},
        {"dimension": "user_acceptance", "threshold": 1, "unit": "bool", "type": "hard", "comparator": "=="}
      ]
    },
    "T5": {
      "name": "Iterate",
      "gates": [
        {"dimension": "kpi_target", "threshold": null, "unit": "user_defined", "type": "hard", "comparator": ">=", "note": "threshold set in plan", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}}
      ]
    },
    "T6": {
      "name": "Generate",
      "gates": [
        {"dimension": "pass_rate", "threshold": 90, "unit": "%", "type": "hard", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}},
        {"dimension": "avg_score", "threshold": 7, "unit": "/10", "type": "hard", "comparator": ">=", "llm_grader": {"enabled": false, "prompt_file": "graders/research-depth.md", "trigger": "when_confidence_is_heuristic"}}
      ]
    },
    "T7": {
      "name": "Quality",
      "gates": [
        {"dimension": "security", "threshold": 9, "unit": "/10", "type": "hard", "comparator": ">="},
        {"dimension": "reliability", "threshold": 8, "unit": "/10", "type": "hard", "comparator": ">="},
        {"dimension": "maintainability", "threshold": 8, "unit": "/10", "type": "hard", "comparator": ">="},
        {"dimension": "p1_count", "threshold": 0, "unit": "count", "type": "hard", "comparator": "=="},
        {"dimension": "security_p2", "threshold": 0, "unit": "count", "type": "hard", "comparator": "=="},
        {"dimension": "reliability_p2", "threshold": 3, "unit": "count", "type": "soft", "comparator": "<="},
        {"dimension": "maintainability_p2", "threshold": 5, "unit": "count", "type": "soft", "comparator": "<="}
      ]
    },
    "T8": {
      "name": "Optimize",
      "gates": [
        {"dimension": "architecture", "threshold": 8, "unit": "/10", "type": "hard", "comparator": ">="},
        {"dimension": "performance", "threshold": 8, "unit": "/10", "type": "hard", "comparator": ">="},
        {"dimension": "stability", "threshold": 8, "unit": "/10", "type": "hard", "comparator": ">="}
      ]
    }
  },
  "completion_authority": {
    "T1": "human_review",
    "T2": "human_review",
    "T3": "human_review",
    "T4": "external_validation",
    "T5": "external_validation",
    "T6": "internal",
    "T7": "internal",
    "T8": "internal"
  },
  "stagnation_thresholds": {
    "T1": {"value": 3, "unit": "%", "type": "relative"},
    "T2": {"value": 3, "unit": "%", "type": "relative"},
    "T3": {"value": 3, "unit": "%", "type": "relative"},
    "T5": {"value": 2, "unit": "%", "type": "relative"},
    "T7": {"value": 0.3, "unit": "points", "type": "absolute"},
    "T8": {"value": 0.5, "unit": "points", "type": "absolute"}
  },
  "stagnation_consecutive": 2,
  "stagnation_max_explore": {
    "T5": 3,
    "T7": 2,
    "T8": 2
  },
  "oscillation": {
    "window": 3,
    "band": 0.5
  },
  "experience_status_enum": ["recommended", "candidate default", "observing", "retired"],
  "strategy_effect_enum": ["keep", "avoid", "to be validated"],
  "phase_enum": ["OBSERVE", "ORIENT", "DECIDE", "ACT", "VERIFY", "SYNTHESIZE", "EVOLVE", "REFLECT"],
  "task_status_enum": ["ready to start", "in progress", "paused awaiting confirmation", "completed"],
  "gate_status_enum": ["pass", "fail", "exempt"],
  "tsv_status_enum": ["pass", "fail", "pending_check", "pending_review"],
  "default_rounds": {
    "T1": 3, "T2": 2, "T3": 3, "T4": 5, "T5": 99,
    "T6": 99, "T7": 99, "T8": 99
  }
}
